# TravelMate Configuration
# Copy this file to .env and fill in your values

# Generate a strong random key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# Database URL (default: SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./travelmate.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/travelmate

# Debug mode (set to False in production)
# DEBUG=False

# JWT token expiration in minutes (default: 60)
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
